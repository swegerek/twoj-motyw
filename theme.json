{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },
    "color": {
      "palette": [
        {
          "name": "Pure White",
          "slug": "bg-light",
          "color": "#ffffff"
        },
        {
          "name": "Light Surface",
          "slug": "bg-surface",
          "color": "#f8f9fa"
        },
        {
          "name": "Card White",
          "slug": "bg-card",
          "color": "#ffffff"
        },
        {
          "name": "Dark Slate Text",
          "slug": "text-main",
          "color": "#1e293b"
        },
        {
          "name": "Slate Muted",
          "slug": "text-muted",
          "color": "#64748b"
        },
        {
          "name": "Vibrant Blue",
          "slug": "primary-blue",
          "color": "#0066ff"
        },
        {
          "name": "Electric Indigo",
          "slug": "accent-purple",
          "color": "#4f46e5"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Outfit', sans-serif",
          "name": "Outfit",
          "slug": "outfit"
        },
        {
          "fontFamily": "'Inter', sans-serif",
          "name": "Inter",
          "slug": "inter"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "size": "0.875rem",
          "slug": "small"
        },
        {
          "name": "Normal",
          "size": "1rem",
          "slug": "normal"
        },
        {
          "name": "Medium",
          "size": "1.25rem",
          "slug": "medium"
        },
        {
          "name": "Large",
          "size": "1.875rem",
          "slug": "large"
        },
        {
          "name": "Huge",
          "size": "2.5rem",
          "slug": "huge"
        },
        {
          "name": "Hero",
          "size": "3.75rem",
          "slug": "hero"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--bg-surface)",
      "text": "var(--wp--preset--color--text-main)"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary-blue)"
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--outfit)"
        }
      }
    }
  }
}
